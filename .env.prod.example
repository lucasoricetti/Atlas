# Runtime WebAPI
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# Neo4j (prod template: password letta da Docker secret file)
NEO4J_URI=neo4j://neo4j:7687
NEO4J_USER=neo4j
NEO4J_DATABASE=neo4j
NEO4J_PASSWORD_FILE=./secrets/prod/neo4j_admin_password.txt

# CORS
Cors__AllowedOrigins__0=https://your-production-domain.com

# Host pubblico usato dalle route Traefik (compose prod corrente)
ATLAS_HOST=your-production-domain.com

# Azure AD / Entra ID (backend)
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-api-app-client-id
AZURE_AD_AUDIENCE=api://your-api-app-client-id
AZURE_AD_INSTANCE=https://login.microsoftonline.com/

# Frontend Vite (build-time: richiede rebuild del container frontend)
VITE_API_BASE_URL=https://your-production-domain.com
VITE_AAD_CLIENT_ID=your-frontend-app-client-id
VITE_AAD_AUTHORITY=https://login.microsoftonline.com/your-tenant-id
VITE_API_SCOPE=api://your-api-app-client-id/user_impersonation

# Override opzionali redirect/frontend
# VITE_APP_ORIGIN=https://your-production-domain.com
# VITE_AAD_REDIRECT_URI=https://your-production-domain.com
# VITE_AAD_POST_LOGOUT_REDIRECT_URI=https://your-production-domain.com/login

# Grafana (prod template: password letta da Docker secret file)
GF_SECURITY_ADMIN_USER=your_grafana_username
GRAFANA_ADMIN_PASSWORD_FILE=./secrets/prod/grafana_admin_password.txt

# TLS Traefik: path assoluti host Linux montati read-only in /certs/tls.crt e /certs/tls.key
TRAEFIK_CERT_FILE_HOST=/your/path/to/certs/your-production-domain.com.crt
TRAEFIK_CERT_KEY_FILE_HOST=/your/path/to/certs/your-production-domain.com.key

# Image tags (allineati al compose production)
SOCKET_PROXY_IMAGE_TAG=v0.4.2
TRAEFIK_IMAGE_TAG=v3.6
PROMETHEUS_IMAGE_TAG=v3.11.2
GRAFANA_IMAGE_TAG=13.0.1
NEO4J_IMAGE_TAG=5.26-community
WEBAPI_IMAGE_REPOSITORY=atlas/webapi
WEBAPI_IMAGE_TAG=1.0.0
FRONTEND_IMAGE_REPOSITORY=atlas/frontend
FRONTEND_IMAGE_TAG=1.0.0