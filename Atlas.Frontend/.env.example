# Local frontend-only development template (npm run dev)
# Note: Docker Compose does not read this file.

# Required
VITE_API_BASE_URL=http://localhost:5173
VITE_AAD_CLIENT_ID=your-frontend-app-client-id
VITE_AAD_AUTHORITY=https://login.microsoftonline.com/your-tenant-id
VITE_API_SCOPE=api://your-api-app-client-id/user_impersonation

# Optional overrides
# VITE_APP_ORIGIN=http://localhost:5173
# VITE_AAD_REDIRECT_URI=http://localhost:5173
# VITE_AAD_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/login
